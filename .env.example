# ─────────────────────────────────────────────────────────────────────────────
# Environment configuration — copy to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=enwise_db
DB_USER=postgres
DB_PASSWORD=change_me_strong_password

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=replace_with_64_hex_chars
JWT_REFRESH_SECRET_KEY=replace_with_another_64_hex_chars
ALGORITHM=HS256

# Token lifetimes (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080    # 7 days

# ── Account lockout ────────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5         # failed attempts before lockout
LOCKOUT_MINUTES=15           # lockout duration

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REFRESH=20/minute
RATE_LIMIT_DEFAULT=60/minute

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
