# ─────────────────────────────────────────────────────────────────────────────
# Environment configuration — copy to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=enwise_db
DB_USER=postgres
DB_PASSWORD=change_me_strong_password

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=replace_with_64_hex_chars
JWT_REFRESH_SECRET_KEY=replace_with_another_64_hex_chars
ALGORITHM=HS256

# Token lifetimes (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=263520   # ~6 months (60 * 24 * 183)
REFRESH_TOKEN_EXPIRE_MINUTES=525600   # 365 days (60 * 24 * 365)

# ── Account lockout ────────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5         # failed attempts before lockout
LOCKOUT_MINUTES=15           # lockout duration

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REFRESH=20/minute
RATE_LIMIT_DEFAULT=60/minute

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── FCM (Firebase Cloud Messaging) ──────────────────────────────────────────
FCM_CREDENTIALS_PATH=path/to/firebase-credentials.json

# ── HillPing Platform ────────────────────────────────────────────────────────
MEDIATOR_MATCH_HOTLINE=6384075907   # mediator app "Call" after match (E.164 digits ok)
PING_TTL_SECONDS=30              # owner has 30s to respond
COMMISSION_PERCENTAGE=10         # platform takes 10%
INSTANT_CONFIRM_THRESHOLD=95     # auto-confirm if acceptance rate >= 95%

# ── V2: Mediator Settings ───────────────────────────────────────────────────
VISIT_HOLD_TTL_SECONDS=2700      # 45 minutes room hold
MAX_BULK_PING=3                  # max properties per bulk ping
MAX_TOUR_STOPS=3                 # max stops per tour
GUEST_ACCESS_CODE_VALIDITY_HOURS=24
RESIDUAL_COMMISSION_MONTHS=12    # mediator earns residual for 12 months

# ── SMS Gateway (choose one: msg91 or twilio) ───────────────────────────────
SMS_PROVIDER=                    # msg91 | twilio
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
