# ─────────────────────────────────────────────────────────────────────────────
# Environment configuration — copy to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hotel_booking
DB_USER=postgres
DB_PASSWORD=ram

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=e920cb7de67771e5c2a3c0d826027b0ec96277d61ef84d6a60dffb17ad59cbce258db0a7d11a91a886a4b0443c87526ba939b4efa41929d30548f5884f5ee1b4
JWT_REFRESH_SECRET_KEY=4c4c96f05ef8b59afbb26877f5e863b4fba3a22bdfdc0e7683684e73ebf04c7f036d50f5964e586744859f4fd575a48ad4198103502dcf6087c0cf89e7bb0f25
ALGORITHM=HS256

# Token lifetimes (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080    

# ── Account lockout ────────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5         
LOCKOUT_MINUTES=15         

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REFRESH=20/minute
RATE_LIMIT_DEFAULT=60/minute

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── FCM (Firebase Cloud Messaging) ──────────────────────────────────────────
FCM_CREDENTIALS_PATH=

# ── HillPing Platform ────────────────────────────────────────────────────────
PING_TTL_SECONDS=30
COMMISSION_PERCENTAGE=10
INSTANT_CONFIRM_THRESHOLD=95

# ── V2: Mediator Settings ───────────────────────────────────────────────────
VISIT_HOLD_TTL_SECONDS=2700
MAX_BULK_PING=3
MAX_TOUR_STOPS=3
GUEST_ACCESS_CODE_VALIDITY_HOURS=24
RESIDUAL_COMMISSION_MONTHS=12

# ── SMS Gateway ──────────────────────────────────────────────────────────────
SMS_PROVIDER=
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
